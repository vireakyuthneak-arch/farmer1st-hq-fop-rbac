# Copy to .env (stays gitignored, chmod 600) and fill in. Never commit .env.

# Cloudflare — used by scripts/cf-onboard.sh
# Token scopes: Account Settings: Members (Edit) · Access: Orgs, IdPs & Groups (Edit) · Account (Read)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional: dedicated KV-only token (Workers KV Storage: Edit) for the
# fop-rbac app-RBAC namespace; falls back to CLOUDFLARE_API_TOKEN if unset.
#CLOUDFLARE_KV_API_TOKEN=

# GitHub — only needed for full terraform runs (org invites + teams)
# Fine-grained org token: org members + team members read/write
#GITHUB_TOKEN=
