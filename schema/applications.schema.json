{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.farmer1st.tech/fop/schema/applications.schema.json",
  "title": "FOP application registry",
  "type": "object",
  "required": ["schemaVersion", "applications"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "applications": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/application" }
    }
  },
  "$defs": {
    "application": {
      "type": "object",
      "required": ["name", "kind", "roles"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "kind": {
          "enum": ["internal-cf", "external"],
          "description": "internal-cf = enforced via the fop-rbac KV; external = recorded only, never enforced"
        },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "description": "ORDERED weakest -> strongest; also the conflict-resolution order"
        },
        "defaultRole": {
          "type": "string",
          "minLength": 1,
          "description": "role every FOP user receives at minimum (must be in roles)"
        }
      }
    }
  }
}
