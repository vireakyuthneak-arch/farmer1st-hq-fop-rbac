{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.farmer1st.tech/fop/schema/catalog.schema.json",
  "title": "FOP app catalog",
  "type": "object",
  "required": ["schemaVersion", "apps"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "apps": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/app" }
    }
  },
  "$defs": {
    "app": {
      "type": "object",
      "required": ["name", "source", "id", "version"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source": {
          "enum": ["formula", "cask"],
          "description": "ADR-0020: Homebrew formulae + public casks only. App Store / direct-download apps are out of FOP scope (MDM/VPP)."
        },
        "id": { "type": "string", "minLength": 1 },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "'latest' to track, or a specific pinned version"
        },
        "category": { "type": "string" }
      }
    }
  }
}
