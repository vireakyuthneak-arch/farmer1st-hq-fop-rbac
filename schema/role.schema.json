{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.farmer1st.tech/fop/schema/role.schema.json",
  "title": "FOP role profile",
  "type": "object",
  "required": ["schemaVersion", "role", "apps"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "role": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "description": { "type": "string" },
    "apps": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "system": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true,
      "description": "trust-plane installer ids (admin-requiring installs, e.g. docker-desktop) — rendered into the manifest's system[], installed by the daemon's root plane"
    },
    "whitelist": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9@./-]+$" },
      "uniqueItems": true,
      "description": "tolerated self-installs (ADR-0011): brew names the daemon must never reap even though it didn't install them"
    },
    "appRoles": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "additionalProperties": { "type": "string", "minLength": 1 },
      "description": "app id (profiles/applications.yml) -> role held IN that app; multi-role users resolve strongest-wins"
    },
    "cloud": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aws": {
          "type": "object",
          "required": ["grants"],
          "additionalProperties": false,
          "properties": {
            "grants": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["account", "permissionSet"],
                "additionalProperties": false,
                "properties": {
                  "account": {
                    "type": "string",
                    "minLength": 1,
                    "description": "logical account name, resolved to a real id via terraform var.account_ids"
                  },
                  "permissionSet": {
                    "type": "string",
                    "minLength": 1,
                    "description": "permission-set name from the catalog in terraform/aws-foundation.tf"
                  }
                }
              }
            }
          }
        },
        "github": {
          "type": "object",
          "required": ["org", "teams"],
          "additionalProperties": false,
          "properties": {
            "org": { "type": "string", "minLength": 1 },
            "teams": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        },
        "cloudflare": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "accessGroups": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "dashboardRole": {
              "type": "string",
              "minLength": 1,
              "description": "Cloudflare account role name (e.g. Administrator) — grants dashboard membership via an invite email"
            }
          }
        }
      }
    }
  }
}
