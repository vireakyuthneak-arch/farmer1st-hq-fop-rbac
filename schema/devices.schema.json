{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.farmer1st.tech/fop/schema/devices.schema.json",
  "title": "FOP device map (serial -> user)",
  "type": "object",
  "required": ["schemaVersion", "devices"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "devices": {
      "type": "object",
      "description": "Mac hardware serial -> user key (== GitHub login once confirmed). Rendered verbatim into manifests/index.json so the daemon resolves devices by lookup, not scan.",
      "propertyNames": { "pattern": "^[A-Z0-9]{8,14}$" },
      "additionalProperties": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "minProperties": 1
    }
  }
}
