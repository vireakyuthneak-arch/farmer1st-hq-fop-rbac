{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.farmer1st.tech/fop/schema/user.schema.json",
  "title": "FOP user assignment",
  "type": "object",
  "required": ["schemaVersion", "user", "identity", "roles"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "user": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "identity": {
      "type": "object",
      "required": ["email"],
      "additionalProperties": false,
      "properties": {
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "github": {
          "type": "string",
          "minLength": 1,
          "description": "required only when a role grants GitHub teams — never use placeholders (handle squatting risk)"
        },
        "awsUserName": { "type": "string", "minLength": 1 }
      }
    },
    "devices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["serial"],
        "additionalProperties": false,
        "properties": {
          "serial": { "type": "string", "minLength": 1 },
          "hostname": { "type": "string" }
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
      "uniqueItems": true
    },
    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "add": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        },
        "remove": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "uniqueItems": true
        }
      }
    }
  }
}
